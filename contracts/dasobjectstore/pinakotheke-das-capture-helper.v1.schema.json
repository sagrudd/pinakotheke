{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sagrudd/pinakotheke/contracts/dasobjectstore/pinakotheke-das-capture-helper.v1.schema.json",
  "title": "Pinakotheke DASObjectStore capture helper configuration v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "endpoint_id", "curl_executable", "submit_to_daemon"],
  "oneOf": [
    {
      "required": ["dasobjectstore_remote_executable", "dasobjectstore_remote_config", "daemon_socket"],
      "not": {"required": ["container_execution"]}
    },
    {
      "required": ["container_execution"],
      "not": {
        "anyOf": [
          {"required": ["dasobjectstore_remote_executable"]},
          {"required": ["dasobjectstore_remote_config"]},
          {"required": ["daemon_socket"]}
        ]
      }
    }
  ],
  "properties": {
    "schema_version": {"const": "pinakotheke.das-capture-helper.v1"},
    "endpoint_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "curl_executable": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "submit_to_daemon": {"const": true},
    "ffprobe_executable": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "dasobjectstore_remote_executable": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "dasobjectstore_remote_config": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "daemon_socket": {"type": "string", "pattern": "^/", "maxLength": 4096},
    "container_execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["docker_executable", "compose_file", "managed_scratch_root", "container_scratch_root", "remote_config", "aws_credentials", "service", "daemon_socket"],
      "properties": {
        "docker_executable": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "compose_file": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "managed_scratch_root": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "container_scratch_root": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "remote_config": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "aws_credentials": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "service": {"const": "dasobjectstored"},
        "daemon_socket": {"const": "/run/dasobjectstore/dasobjectstored.sock"}
      }
    },
    "max_image_bytes": {"type": "integer", "minimum": 1, "maximum": 1073741824},
    "max_video_bytes": {"type": "integer", "minimum": 1, "maximum": 8589934592},
    "normalization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["docker_executable", "ingest_helper", "executor_ref", "staging_ref", "staging_root", "image_reference", "image_digest", "cpu_millis_limit", "memory_bytes_limit", "scratch_bytes_limit", "firefox_playback_evidence_id", "codec_gap_journal"],
      "properties": {
        "docker_executable": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "ingest_helper": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "executor_ref": {"$ref": "#/$defs/identifier"},
        "staging_ref": {"$ref": "#/$defs/identifier"},
        "staging_root": {"type": "string", "pattern": "^/", "maxLength": 4096},
        "image_reference": {"type": "string", "pattern": "^registry://[^@ ?#]+$", "maxLength": 512},
        "image_digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
        "cpu_millis_limit": {"type": "integer", "minimum": 1},
        "memory_bytes_limit": {"type": "integer", "minimum": 1},
        "scratch_bytes_limit": {"type": "integer", "minimum": 1},
        "firefox_playback_evidence_id": {"$ref": "#/$defs/identifier"},
        "codec_gap_journal": {"type": "string", "pattern": "^/", "maxLength": 4096}
      }
    }
  },
  "$defs": {
    "identifier": {"type": "string", "pattern": "^[A-Za-z0-9._:-]{1,128}$"}
  }
}
