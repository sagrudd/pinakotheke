{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sagrudd/x-img/schemas/x-img-website-policy.v1.schema.json",
  "title": "x-img website policy configuration v1",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "x-img.website-policy.v1" },
    "site_id": { "$ref": "x-img-common.v1.schema.json#/$defs/identifier" },
    "origin": { "$ref": "x-img-common.v1.schema.json#/$defs/origin" },
    "enabled": { "type": "boolean" },
    "capture_enabled": { "type": "boolean" },
    "substitution_enabled": { "type": "boolean" },
    "media_policy": { "$ref": "x-img-common.v1.schema.json#/$defs/mediaPolicy" },
    "candidate_budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_candidates_per_page": { "type": "integer", "minimum": 0 },
        "max_bytes_per_candidate": { "type": "integer", "minimum": 0 },
        "max_candidates_per_day": { "type": "integer", "minimum": 0 }
      },
      "required": [
        "max_candidates_per_page",
        "max_bytes_per_candidate",
        "max_candidates_per_day"
      ]
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["explicit", "experimental_generic"] },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" }
      },
      "required": ["kind", "version"]
    },
    "review_defaults": { "$ref": "x-img-common.v1.schema.json#/$defs/reviewDefaults" }
  },
  "required": [
    "schema_version",
    "site_id",
    "origin",
    "enabled",
    "capture_enabled",
    "substitution_enabled",
    "media_policy",
    "candidate_budget",
    "adapter",
    "review_defaults"
  ],
  "allOf": [
    {
      "if": { "properties": { "enabled": { "const": true } } },
      "then": { "required": ["capture_enabled", "substitution_enabled"] }
    }
  ]
}
